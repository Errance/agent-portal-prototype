# agent-portal 环境变量样例。复制为 .env.local 或在 CI 里注入。
# 注意：VITE_ 前缀变量会进前端 bundle，不能放机密。

# ---------- mock 开关 ----------
#   true  → 总是 mock
#   false → 总是走真实 API
#   不设置 → DEV 默认 mock，生产默认真实 API（推荐）
# VITE_USE_MOCK=true

# ---------- 真实 API ----------
# sit 默认
VITE_API_BASE=https://surfv2-sit-api.nfexinsider.com

# 业务平台标识（由后端指定，sit 待确认）
VITE_BIZ_PF=4

# ---------- 路由 ----------
# 留空 = HashRouter（GitHub Pages 子路径部署）
# browser = BrowserRouter（需 nginx try_files 等 SPA fallback）
# VITE_ROUTER=

# ---------- 构建 base ----------
# 由 GitHub Actions repository variable 注入；本地开发不需要设置
# VITE_BASE=/agent-portal-prototype/

# ---------- Privy ----------
# agent-portal 当前对接 surf-one 的后端（surfv2-sit-api.nfexinsider.com），
# 所以 Privy App ID 必须和 surf-one 一致（否则 /login 校验 JWT.aud 失败）：
#   surf-one sit  = cm3zc6y73001tjxd1ui968tg7
#   surf-one uat  = cm5kuia7c00sh95pbyde20fbz
#   surf-one prod = cm5unv2qb07ig23v255jqe4r2
#
# 未来若迁到 turboflow 自己的后端，换成 turboflow App ID：
#   turboflow sit  = cmbir1ip600bejx0mu6b42iek
#   turboflow uat  = cmdsozhfd004mlb0b47ukqv7s
#   turboflow prod = cmcjy9lbg0028l70m9owhg0oa
VITE_PRIVY_APP_ID=cm3zc6y73001tjxd1ui968tg7
