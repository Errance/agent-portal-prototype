# agent-portal 环境变量样例。复制为 .env.local 或在 CI 里注入。
# 注意：VITE_ 前缀变量会进前端 bundle，不能放机密。

# ---------- mock 开关 ----------
#   true  → 总是 mock
#   false → 总是走真实 API
#   不设置 → DEV 默认 mock，生产默认真实 API（推荐）
# VITE_USE_MOCK=true

# ---------- 真实 API ----------
# sit 默认
VITE_API_BASE=https://surfv2-sit-api.nfexinsider.com

# 业务平台标识（由后端指定，sit 待确认）
VITE_BIZ_PF=4

# ---------- 路由 ----------
# 留空 = HashRouter（GitHub Pages 子路径部署）
# browser = BrowserRouter（需 nginx try_files 等 SPA fallback）
# VITE_ROUTER=

# ---------- 构建 base ----------
# 由 GitHub Actions repository variable 注入；本地开发不需要设置
# VITE_BASE=/agent-portal-prototype/

# ---------- Privy ----------
# 后端 surfv2-sit-api.nfexinsider.com /login aud 校验对齐的 App ID（surf-one sit）：
#   sit  = cm3zc6y73001tjxd1ui968tg7   # surf-one 业务 sit（后端已调高 user limit）
#   uat  = cm5kuia7c00sh95pbyde20fbz
#   prod = cm5unv2qb07ig23v255jqe4r2
VITE_PRIVY_APP_ID=cm3zc6y73001tjxd1ui968tg7
